{
  "include": [
    "src",
    "tests"
  ],
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "standard",
  "reportMissingTypeStubs": false,
  "executionEnvironments": [
    {
      "root": "src",
      "extraPaths": [
        "src"
      ]
    },
    {
      "root": "tests",
      "extraPaths": [
        "src"
      ]
    }
  ]
}
